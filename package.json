{
  "name": "aegis-security-cli",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Authorized passive security testing CLI with scope guard, multilingual docs, redacted reports, and safe-by-default checks.",
  "license": "MIT",
  "keywords": [
    "security-tools",
    "web-security",
    "owasp",
    "passive-scanner",
    "security-automation",
    "cli",
    "i18n",
    "sarif",
    "redaction",
    "authorized-testing",
    "mitre-attack",
    "attack-emulation",
    "defensive-security",
    "security-scanner"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeeHueeng/privit-project.git"
  },
  "bugs": {
    "url": "https://github.com/LeeHueeng/privit-project/issues"
  },
  "homepage": "https://github.com/LeeHueeng/privit-project#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "bin/",
    "src/",
    "scripts/generate-catalog.js",
    "catalog/security-checks.jsonl",
    "docs/",
    "aegis.policy.json",
    "aegis.scope.json",
    "aegis.auth.json",
    "README.md",
    "README.ko.md",
    "README.ja.md",
    "README.zh-CN.md",
    "LICENSE"
  ],
  "bin": {
    "aegis": "./bin/aegis.js"
  },
  "scripts": {
    "aegis": "node ./bin/aegis.js",
    "catalog:generate": "node ./scripts/generate-catalog.js",
    "docs:generate": "node ./bin/aegis.js docs generate",
    "docs:generate:ko": "node ./bin/aegis.js docs generate --lang ko-KR",
    "docs:generate:ja": "node ./bin/aegis.js docs generate --lang ja-JP",
    "docs:generate:zh": "node ./bin/aegis.js docs generate --lang zh-CN",
    "docs:generate:en": "node ./bin/aegis.js docs generate --lang en-US",
    "security:init": "node ./bin/aegis.js init",
    "security:plan": "node ./bin/aegis.js plan --mode safe_active",
    "security:frontend": "node ./bin/aegis.js run --target frontend",
    "security:api": "node ./bin/aegis.js run --target backend_api",
    "security:ci": "node ./bin/aegis.js run --mode ci",
    "security:report": "node ./bin/aegis.js report --format html",
    "test": "node --test"
  },
  "engines": {
    "node": ">=20"
  }
}
